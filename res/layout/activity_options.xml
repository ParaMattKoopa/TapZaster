<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/options_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SETTINGS"
        android:textSize="28sp"
        android:gravity="center"
        android:padding="15dp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="5dp">

            <Button android:id="@+id/btn_about" 
                    android:layout_width="match_parent" 
                    android:layout_height="60dp" 
                    android:text="About TapZaster..." />

            <Button android:id="@+id/btn_save1" 
                    android:layout_width="match_parent" 
                    android:layout_height="60dp" 
                    android:text="Saves: Slot 1" />

            <Button android:id="@+id/btn_save2" 
                    android:layout_width="match_parent" 
                    android:layout_height="60dp" 
                    android:text="Saves: Slot 2" />
			<Button android:id="@+id/btn_Restall" 
                    android:layout_width="match_parent" 
                    android:layout_height="60dp" 
                    android:text="DELETE ALL GAME DATA (do not click unless if you know what you are doing)" />
            </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Close"
        android:layout_marginTop="10dp" />

</LinearLayout>